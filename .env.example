# ============================================
# Momentum Project - Environment Variables
# ============================================
# Copy this file to .env and fill in your values

# ============================================
# Database (PostgreSQL)
# ============================================
POSTGRES_USER=momentum
POSTGRES_PASSWORD=momentum_secret
POSTGRES_DB=momentum_db
POSTGRES_PORT=5432

# Prisma Database URL (for local development without Docker)
DATABASE_URL=postgresql://momentum:momentum_secret@localhost:5432/momentum_db?schema=public

# ============================================
# MinIO (S3-Compatible Storage)
# ============================================
MINIO_ROOT_USER=momentum_admin
MINIO_ROOT_PASSWORD=momentum_secret_key
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_BUCKET=momentum-uploads

# ============================================
# JWT Authentication
# ============================================
JWT_ACCESS_SECRET=your_super_secret_access_key_change_in_production_min_32_chars
JWT_REFRESH_SECRET=your_super_secret_refresh_key_change_in_production_min_32_chars
JWT_ACCESS_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d

# ============================================
# Application Ports
# ============================================
SERVER_PORT=3001
CLIENT_PORT=3000

# ============================================
# Environment
# ============================================
NODE_ENV=development

# ============================================
# Frontend Environment Variables
# ============================================
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_MINIO_URL=http://localhost:9000
